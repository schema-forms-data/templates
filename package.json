{
  "name": "@schema-forms-data/templates",
  "version": "4.0.7",
  "description": "Template registry and preset blocks for SchemaForms",
  "license": "MIT",
  "author": "SchemaForms",
  "homepage": "https://schemaforms.github.io/schema-forms-data",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchemaFormsData/templates.git"
  },
  "bugs": {
    "url": "https://github.com/SchemaFormsData/templates/issues"
  },
  "keywords": [
    "react",
    "forms",
    "schema",
    "templates",
    "themes",
    "css-variables",
    "schema-forms-data"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@schema-forms-data/core": "^4.0.7"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^4.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
